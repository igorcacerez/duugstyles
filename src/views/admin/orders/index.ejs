<section class="admin-page">
  <div class="admin-heading">
    <div><h1>Pedidos</h1><p>Gerencie pagamento, separacao, envio e pos-venda.</p></div>
  </div>
  <div class="admin-card">
    <table class="admin-table">
      <thead><tr><th>Pedido</th><th>Cliente</th><th>Status</th><th>Pagamento</th><th>Total</th><th></th></tr></thead>
      <tbody>
        <% orders.forEach((order) => { %>
          <tr>
            <td><strong><%= order.number %></strong><br><small><%= order.createdAt?.toLocaleDateString('pt-BR') %></small></td>
            <td><%= order.Customer?.fullName || order.Customer?.email || '-' %></td>
            <td><span class="status-pill"><%= order.status %></span></td>
            <td><%= order.Payment?.status || '-' %></td>
            <td>R$ <%= Number(order.total || 0).toFixed(2).replace('.', ',') %></td>
            <td><a class="btn btn-sm btn-outline-dark" href="/admin/pedidos/<%= order.id %>">Abrir</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
