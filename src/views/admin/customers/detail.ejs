<section class="admin-page">
  <div class="admin-heading">
    <div><h1><%= customer.fullName || customer.email %></h1><p><%= customer.email %> · <%= customer.phone || 'sem telefone' %></p></div>
    <a class="btn btn-outline-dark" href="/admin/clientes">Voltar</a>
  </div>
  <div class="admin-card">
    <form method="post" action="/admin/clientes/<%= customer.id %>/bloqueio">
      <button class="btn <%= customer.isBlocked ? 'btn-gold' : 'btn-outline-danger' %>"><%= customer.isBlocked ? 'Desbloquear cliente' : 'Bloquear cliente' %></button>
    </form>
  </div>
  <div class="admin-card">
    <h2>Pedidos do cliente</h2>
    <table class="admin-table">
      <thead><tr><th>Pedido</th><th>Status</th><th>Total</th><th></th></tr></thead>
      <tbody>
        <% customer.Orders.forEach((order) => { %>
          <tr>
            <td><%= order.number %></td>
            <td><%= order.status %></td>
            <td>R$ <%= Number(order.total || 0).toFixed(2).replace('.', ',') %></td>
            <td><a class="btn btn-sm btn-outline-dark" href="/admin/pedidos/<%= order.id %>">Abrir pedido</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
