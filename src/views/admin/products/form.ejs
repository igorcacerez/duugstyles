<%
  const action = product ? `/admin/produtos/${product.id}` : '/admin/produtos';
  const images = product?.ProductImages || [];
  const variations = product?.ProductVariations?.length ? product.ProductVariations : [];
  const selectedSizeIds = [...new Set(variations.map((variation) => variation.sizeId).filter(Boolean))];
  const selectedColorIds = [...new Set(variations.map((variation) => variation.colorId).filter(Boolean))];
  const variationJson = variations.map((variation) => ({
    sizeId: variation.sizeId,
    colorId: variation.colorId,
    sku: variation.sku,
    price: variation.price,
    stock: variation.stock,
    imageUrl: variation.imageUrl || ''
  }));
%>
<section class="admin-page">
  <div class="admin-heading">
    <div>
      <h1><%= product ? 'Editar produto' : 'Novo produto' %></h1>
      <p>Escolha tamanhos e cores. O sistema gera automaticamente todas as combinacoes possiveis.</p>
    </div>
    <a class="btn btn-outline-dark" href="/admin/produtos">Voltar</a>
  </div>

  <form method="post" action="<%= action %>" class="admin-card admin-form" enctype="multipart/form-data" data-product-form>
    <h2>Dados do produto</h2>
    <div class="admin-form-grid">
      <label>Nome<input class="form-control" name="name" value="<%= product?.name || '' %>" required></label>
      <label>Slug<input class="form-control" name="slug" value="<%= product?.slug || '' %>" placeholder="gerado automaticamente"></label>
      <label>Categoria<select class="form-select" name="categoryId"><% categories.forEach((c) => { %><option value="<%= c.id %>" <%= product?.categoryId === c.id ? 'selected' : '' %>><%= c.name %></option><% }) %></select></label>
      <label>Preco base<input class="form-control" name="price" value="<%= product?.price || '' %>" required></label>
      <label>Preco promocional base<input class="form-control" name="promoPrice" value="<%= product?.promoPrice || '' %>"></label>
      <label>Custo<input class="form-control" name="cost" value="<%= product?.cost || '' %>"></label>
    </div>
    <label>Descricao curta<textarea class="form-control" name="descriptionShort" rows="2"><%= product?.descriptionShort || '' %></textarea></label>
    <label>Descricao completa<textarea class="form-control" name="descriptionLong" rows="4"><%= product?.descriptionLong || '' %></textarea></label>

    <h2>Imagens do produto</h2>
    <p class="admin-help">Arraste ou selecione varias imagens. A primeira imagem enviada vira a principal quando o produto ainda nao tiver galeria.</p>
    <% if (images.length) { %>
      <div class="admin-image-grid">
        <% images.forEach((image) => { %>
          <div class="admin-image-card">
            <img src="<%= image.imageUrl %>" alt="<%= image.altText || product.name %>">
            <small><%= image.isMain ? 'Imagem principal' : 'Galeria' %></small>
            <button class="btn btn-sm btn-outline-danger" type="submit" form="remove-image-<%= image.id %>">Remover</button>
          </div>
        <% }) %>
      </div>
    <% } %>
    <label class="upload-dropzone" data-dropzone>
      <input type="file" name="images" accept="image/*" multiple data-dropzone-input>
      <span>Solte as imagens aqui ou clique para selecionar</span>
      <small>PNG, JPG ou WEBP ate 5MB por arquivo</small>
    </label>
    <div class="upload-preview-grid" data-upload-preview></div>
    <label>Texto alt padrao<input class="form-control" name="altText" value="<%= images[0]?.altText || product?.name || '' %>"></label>

    <h2>Gerador de variações</h2>
    <p class="admin-help">Exemplo: tamanhos P, M e G + cores Azul e Preto criam Preto P, Preto M, Preto G, Azul P, Azul M e Azul G.</p>
    <div class="attribute-builder">
      <div>
        <strong>Tamanhos</strong>
        <div class="attribute-chip-grid">
          <% sizes.forEach((size) => { %>
            <label class="attribute-chip">
              <input type="checkbox" name="selectedSizeIds" value="<%= size.id %>" data-size-name="<%= size.name %>" <%= selectedSizeIds.includes(size.id) ? 'checked' : '' %>>
              <span><%= size.name %></span>
            </label>
          <% }) %>
        </div>
      </div>
      <div>
        <strong>Cores</strong>
        <div class="attribute-chip-grid">
          <% colors.forEach((color) => { %>
            <label class="attribute-chip">
              <input type="checkbox" name="selectedColorIds" value="<%= color.id %>" data-color-name="<%= color.name %>" data-color-hex="<%= color.hexCode || '#999999' %>" <%= selectedColorIds.includes(color.id) ? 'checked' : '' %>>
              <span><i style="--swatch:<%= color.hexCode || '#999999' %>"></i><%= color.name %></span>
            </label>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="variation-toolbar">
      <button class="btn btn-outline-dark" type="button" data-generate-variations>Gerar variações</button>
      <span data-variation-count><%= variations.length %> variacao(oes)</span>
    </div>
    <div class="variation-matrix" data-variation-matrix data-existing-variations='<%- JSON.stringify(variationJson) %>'></div>

    <h2>SEO</h2>
    <div class="admin-form-grid">
      <label>Meta title<input class="form-control" name="metaTitle" value="<%= product?.metaTitle || '' %>"></label>
      <label>Meta description<input class="form-control" name="metaDescription" value="<%= product?.metaDescription || '' %>"></label>
      <label>Palavras-chave<input class="form-control" name="keywords" value="<%= product?.keywords || '' %>"></label>
    </div>
    <div class="admin-form-grid three">
      <label>Peso<input class="form-control" name="weight" value="<%= product?.weight || '' %>"></label>
      <label>Altura<input class="form-control" name="height" value="<%= product?.height || '' %>"></label>
      <label>Largura<input class="form-control" name="width" value="<%= product?.width || '' %>"></label>
      <label>Comprimento<input class="form-control" name="length" value="<%= product?.length || '' %>"></label>
    </div>
    <div class="switch-row">
      <label><input type="checkbox" name="isFeatured" <%= product?.isFeatured ? 'checked' : '' %>> Destaque</label>
      <label><input type="checkbox" name="isNew" <%= !product || product?.isNew ? 'checked' : '' %>> Novo</label>
      <label><input type="checkbox" name="isBestSeller" <%= product?.isBestSeller ? 'checked' : '' %>> Mais vendido</label>
      <label><input type="checkbox" name="isActive" <%= !product || product?.isActive ? 'checked' : '' %>> Ativo</label>
    </div>
    <button class="btn btn-gold">Salvar produto</button>
  </form>

  <% if (product) { %>
    <% images.forEach((image) => { %>
      <form id="remove-image-<%= image.id %>" method="post" action="/admin/produtos/<%= product.id %>/imagens/<%= image.id %>/remover"></form>
    <% }) %>
  <% } %>
</section>
