<div class="container py-4"><h1>Novo produto</h1><form method="post" action="/admin/produtos" class="row g-2"><div class="col-md-6"><input class="form-control" name="name" placeholder="Nome" required></div><div class="col-md-6"><input class="form-control" name="price" placeholder="Preço" required></div><div class="col-md-6"><select class="form-select" name="categoryId"><% categories.forEach(c=>{ %><option value="<%= c.id %>"><%= c.name %></option><% }) %></select></div><div class="col-md-6"><input class="form-control" name="slug" placeholder="Slug"></div><div class="col-12"><button class="btn btn-gold">Salvar</button></div></form></div>
