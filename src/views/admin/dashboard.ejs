<section class="admin-page">
  <div class="admin-heading">
    <div>
      <h1>Dashboard</h1>
      <p>Visao geral de vendas, catalogo e operacao da loja.</p>
    </div>
    <a class="btn btn-gold" href="/admin/produtos/novo">Novo produto</a>
  </div>

  <div class="metric-grid">
    <div class="metric-card"><span>Produtos</span><strong><%= stats.products %></strong></div>
    <div class="metric-card"><span>Pedidos</span><strong><%= stats.orders %></strong></div>
    <div class="metric-card"><span>Clientes</span><strong><%= stats.customers %></strong></div>
    <div class="metric-card"><span>Receita paga</span><strong>R$ <%= stats.revenue.toFixed(2).replace('.', ',') %></strong></div>
  </div>

  <div class="admin-card">
    <div class="admin-heading">
      <div>
        <h1>Pedidos recentes</h1>
        <p>Atalhos para separacao, pagamento e entrega.</p>
      </div>
      <a class="btn btn-outline-dark" href="/admin/pedidos">Ver pedidos</a>
    </div>
    <table class="admin-table">
      <thead><tr><th>Pedido</th><th>Cliente</th><th>Status</th><th>Total</th><th></th></tr></thead>
      <tbody>
        <% recentOrders.forEach((order) => { %>
          <tr>
            <td><strong><%= order.number %></strong></td>
            <td><%= order.Customer?.fullName || order.Customer?.email || '-' %></td>
            <td><span class="status-pill"><%= order.status %></span></td>
            <td>R$ <%= Number(order.total || 0).toFixed(2).replace('.', ',') %></td>
            <td><a class="btn btn-sm btn-outline-dark" href="/admin/pedidos/<%= order.id %>">Abrir</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
