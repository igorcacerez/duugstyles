<section class="page-hero compact-hero">
  <div class="container success-state">
    <i data-lucide="badge-check"></i>
    <span class="eyebrow">Pedido confirmado</span>
    <h1>Compra recebida</h1>
    <p>Numero: <strong><%= order?.number %></strong></p>
    <p>Status do pagamento: <strong><%= order?.payment %></strong></p>
    <% if (order?.total) { %><p>Total: <strong>R$ <%= Number(order.total).toFixed(2).replace('.', ',') %></strong></p><% } %>
    <a href="/" class="btn btn-gold">Voltar para loja</a>
  </div>
</section>
