<div class="container py-5"><h1>Busca</h1><form class="mb-3"><input class="form-control" name="q" value="<%= q %>" placeholder="Buscar produtos"></form><div class="row g-3"><% products.forEach(p=>{ %><div class="col-6 col-md-3"><div class="product-card p-3"><h2 class="h6"><%= p.name %></h2><a href="/produto/<%= p.slug %>" class="btn btn-gold btn-sm">Ver</a></div></div><% }) %></div></div>
