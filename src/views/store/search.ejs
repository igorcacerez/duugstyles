<section class="page-hero compact-hero">
  <div class="container">
    <span class="eyebrow">Busca inteligente</span>
    <h1>Encontre seu proximo streetwear</h1>
    <p>Pesquise por camiseta, moletom, oversized, cor ou palavra-chave.</p>
    <form class="search-panel" action="/busca" method="get">
      <i data-lucide="search"></i>
      <input class="form-control" name="q" value="<%= q %>" placeholder="Buscar produtos" autofocus>
      <button class="btn btn-gold" type="submit">Buscar</button>
    </form>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-heading">
      <div>
        <span class="eyebrow"><%= products.length %> resultado(s)</span>
        <h2><%= q ? `Resultados para "${q}"` : 'Todos os produtos' %></h2>
      </div>
    </div>
    <% if (products.length) { %>
      <div class="product-grid">
        <% products.forEach((p) => { %>
          <%- include('../partials/product-card', { product: p }) %>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <i data-lucide="search-x"></i>
        <h2>Nenhum produto encontrado</h2>
        <p>Tente buscar por camiseta, moletom ou streetwear.</p>
        <a class="btn btn-gold" href="/busca">Ver todos</a>
      </div>
    <% } %>
  </div>
</section>
