<div class="container py-5"><div class="row"><div class="col-md-6"><img src="/public/images/product-placeholder.jpg" class="img-fluid" alt="<%= product?.name %>" loading="lazy"></div><div class="col-md-6"><h1><%= product?.name %></h1><p><%= product?.descriptionShort %></p><p class="price fs-3">R$ <%= product?.promoPrice || product?.price %></p><form action="/carrinho" method="post"><input type="hidden" name="name" value="<%= product?.name %>"><input type="hidden" name="price" value="<%= product?.promoPrice || product?.price %>"><input class="form-control mb-2" type="number" name="quantity" value="1" min="1"><button class="btn btn-gold" data-loading>Adicionar ao carrinho</button></form></div></div></div>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"Product","name":"<%= product?.name %>","description":"<%= product?.descriptionShort %>","offers":{"@type":"Offer","price":"<%= product?.promoPrice || product?.price %>","priceCurrency":"BRL"}}</script>
