<%
  const galleryImages = product.ProductImages?.length ? product.ProductImages : [];
  const fallbackImage = assetUrl(galleryImages[0]?.imageUrl);
  const variationList = product.ProductVariations || [];
  const defaultVariation = variationList.find((variation) => Number(variation.stock || 0) > 0) || variationList[0] || null;
  const image = assetUrl(defaultVariation?.imageUrl || galleryImages[0]?.imageUrl);
  const price = Number(defaultVariation?.price || product.promoPrice || product.price || 0);
  const originalPrice = Number(product.price || 0);
  const hasPromo = product.promoPrice && Number(product.promoPrice) < originalPrice;
  const availableSizes = [...new Map(variationList.map((variation) => [variation.Size?.id, variation.Size]).filter(([, size]) => size)).values()];
  const availableColors = [...new Map(variationList.map((variation) => [variation.Color?.id, variation.Color]).filter(([, color]) => color)).values()];
  const variationData = variationList.map((variation) => ({
    id: variation.id,
    sku: variation.sku,
    sizeId: variation.sizeId,
    sizeName: variation.Size?.name,
    colorId: variation.colorId,
    colorName: variation.Color?.name,
    colorHex: variation.Color?.hexCode,
    price: Number(variation.price || product.promoPrice || product.price || 0),
    stock: Number(variation.stock || 0),
    image: assetUrl(variation.imageUrl || galleryImages[0]?.imageUrl)
  }));
%>
<section class="product-page">
  <div class="container">
    <nav class="breadcrumb-line" aria-label="breadcrumb">
      <a href="/">Home</a>
      <% if (product.Category) { %>
        <span>/</span>
        <a href="/categoria/<%= product.Category.slug %>"><%= product.Category.name %></a>
      <% } %>
      <span>/</span>
      <strong><%= product.name %></strong>
    </nav>

    <div class="product-layout">
      <div class="product-gallery">
        <div class="gallery-main">
          <img src="<%= image %>" alt="<%= product.name %>" loading="eager" data-product-main-image>
          <% if (hasPromo) { %><span class="gallery-badge">Oferta ativa</span><% } %>
        </div>
        <% if (galleryImages.length > 1 || variationList.some((variation) => variation.imageUrl)) { %>
          <div class="gallery-thumbs">
            <% galleryImages.forEach((galleryImage) => { %>
              <button type="button" data-gallery-thumb="<%= assetUrl(galleryImage.imageUrl) %>"><img src="<%= assetUrl(galleryImage.imageUrl) %>" alt="<%= galleryImage.altText || product.name %>"></button>
            <% }) %>
            <% variationList.filter((variation) => variation.imageUrl).forEach((variation) => { %>
              <button type="button" data-gallery-thumb="<%= assetUrl(variation.imageUrl) %>"><img src="<%= assetUrl(variation.imageUrl) %>" alt="<%= product.name %> <%= variation.Color?.name || '' %> <%= variation.Size?.name || '' %>"></button>
            <% }) %>
          </div>
        <% } %>
        <div class="trust-row">
          <span><i data-lucide="truck"></i> Frete antes do carrinho</span>
          <span><i data-lucide="shield-check"></i> Compra segura</span>
          <span><i data-lucide="refresh-cw"></i> Troca facil</span>
        </div>
      </div>

      <aside class="buy-box">
        <span class="eyebrow">Pronto para envio</span>
        <h1><%= product.name %></h1>
        <p class="product-lead"><%= product.descriptionShort || 'Peca streetwear masculina com tecido premium e caimento urbano.' %></p>
        <div class="product-price-row big">
          <strong class="price" data-product-price>R$ <%= price.toFixed(2).replace('.', ',') %></strong>
          <% if (hasPromo) { %><span class="old-price">R$ <%= originalPrice.toFixed(2).replace('.', ',') %></span><% } %>
        </div>
        <div class="installment">ou em ate 3x sem juros</div>
        <div class="stock-status" data-stock-status><%= defaultVariation ? `${defaultVariation.stock} em estoque` : 'Disponivel' %></div>

        <form action="/carrinho" method="post" class="buy-form" data-loading-form>
          <input type="hidden" name="name" value="<%= product.name %>">
          <input type="hidden" name="slug" value="<%= product.slug %>">
          <input type="hidden" name="price" value="<%= price.toFixed(2) %>" data-product-price-input>
          <input type="hidden" name="image" value="<%= image %>" data-product-image-input>
          <input type="hidden" name="variationId" value="<%= defaultVariation?.id || '' %>" data-variation-id-input>
          <input type="hidden" name="color" value="<%= defaultVariation?.Color?.name || '' %>" data-color-name-input>
          <input type="hidden" name="buyNow" value="0" data-buy-now-input>

          <% if (availableSizes.length) { %>
            <label class="field-label" for="size">Tamanho</label>
            <div class="size-options" role="radiogroup" aria-label="Escolha o tamanho">
              <% availableSizes.forEach((size, index) => { %>
                <label>
                  <input type="radio" name="size" value="<%= size.name %>" data-size-id="<%= size.id %>" <%= defaultVariation?.sizeId === size.id || (!defaultVariation && index === 0) ? 'checked' : '' %>>
                  <span><%= size.name %></span>
                </label>
              <% }) %>
            </div>
          <% } %>

          <% if (availableColors.length) { %>
            <label class="field-label" for="color">Cor</label>
            <div class="color-options" role="radiogroup" aria-label="Escolha a cor">
              <% availableColors.forEach((color, index) => { %>
                <label title="<%= color.name %>">
                  <input type="radio" name="colorChoice" value="<%= color.name %>" data-color-id="<%= color.id %>" <%= defaultVariation?.colorId === color.id || (!defaultVariation && index === 0) ? 'checked' : '' %>>
                  <span style="--swatch:<%= color.hexCode || '#999' %>"></span>
                  <small><%= color.name %></small>
                </label>
              <% }) %>
            </div>
          <% } %>

          <div class="quantity-row">
            <label class="field-label" for="quantity">Quantidade</label>
            <input id="quantity" class="form-control" type="number" name="quantity" value="1" min="1">
          </div>

          <div class="buy-actions">
            <button class="btn btn-gold" type="submit">
              <i data-lucide="shopping-bag"></i>
              Adicionar ao carrinho
            </button>
            <button class="btn btn-dark-action" type="submit" data-buy-now-button>
              <i data-lucide="zap"></i>
              Comprar agora
            </button>
          </div>
        </form>

        <button class="wishlist-wide wishlist-toggle" type="button" data-wishlist data-id="<%= product.slug %>" data-name="<%= product.name %>" data-price="<%= price.toFixed(2) %>" data-url="/produto/<%= product.slug %>" data-image="<%= image %>">
          <i data-lucide="heart"></i>
          Salvar na lista de desejos
        </button>

        <div class="freight-box">
          <div>
            <h2>Calcule seu frete</h2>
            <p>Veja opcoes de envio antes de ir para o carrinho.</p>
          </div>
          <form class="freight-form" data-product-freight>
            <input class="form-control" name="zipcode" inputmode="numeric" autocomplete="postal-code" placeholder="Digite seu CEP" required>
            <button class="btn btn-ghost" type="submit">
              <i data-lucide="truck"></i>
              Calcular
            </button>
          </form>
          <div class="freight-results" data-freight-results></div>
        </div>
      </aside>
    </div>
  </div>
</section>

<section class="section size-guide-section">
  <div class="container size-guide" data-size-guide>
    <div>
      <span class="eyebrow">Guia de tamanhos</span>
      <h2>Descubra o melhor tamanho para suas medidas</h2>
      <p>Informe suas medidas principais. A recomendacao considera torax, cintura e altura para sugerir o caimento mais confortavel.</p>
      <div class="size-form">
        <label>Torax em cm<input class="form-control" type="number" min="70" max="140" data-chest placeholder="Ex: 98"></label>
        <label>Cintura em cm<input class="form-control" type="number" min="60" max="130" data-waist placeholder="Ex: 84"></label>
        <label>Altura em cm<input class="form-control" type="number" min="140" max="220" data-height placeholder="Ex: 178"></label>
        <button class="btn btn-gold" type="button" data-size-calculate>
          <i data-lucide="ruler"></i>
          Recomendar tamanho
        </button>
      </div>
      <div class="size-result" data-size-result aria-live="polite">Preencha suas medidas para ver a recomendacao.</div>
    </div>
    <div class="size-table-wrap">
      <table class="size-table">
        <caption>Tabela de referencia Duug Styles</caption>
        <thead><tr><th>Tamanho</th><th>Torax</th><th>Cintura</th><th>Altura</th></tr></thead>
        <tbody>
          <tr><td>P</td><td>84-92</td><td>70-78</td><td>160-170</td></tr>
          <tr><td>M</td><td>92-100</td><td>78-86</td><td>170-178</td></tr>
          <tr><td>G</td><td>100-108</td><td>86-94</td><td>176-184</td></tr>
          <tr><td>GG</td><td>108-116</td><td>94-104</td><td>182-190</td></tr>
          <tr><td>XG</td><td>116-126</td><td>104-114</td><td>188-200</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Complete o look</span>
        <h2>Produtos relacionados</h2>
      </div>
    </div>
    <div class="product-grid">
      <% related.forEach((p) => { %>
        <%- include('../partials/product-card', { product: p }) %>
      <% }) %>
    </div>
  </div>
</section>

<script type="application/ld+json">
<%- JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.descriptionShort || product.descriptionLong || product.name,
  image: image.startsWith('http') ? image : appUrl + image,
  sku: defaultVariation?.sku || product.slug,
  brand: { '@type': 'Brand', name: 'Duug Styles' },
  offers: {
    '@type': 'Offer',
    price: price.toFixed(2),
    priceCurrency: 'BRL',
    availability: defaultVariation && Number(defaultVariation.stock || 0) <= 0 ? 'https://schema.org/OutOfStock' : 'https://schema.org/InStock',
    url: appUrl + '/produto/' + product.slug
  }
}) %>
</script>
<script type="application/json" id="product-variations-data"><%- JSON.stringify(variationData) %></script>
