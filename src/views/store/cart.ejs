<div class="container py-5"><h1>Carrinho</h1><% cart.forEach((item,idx)=>{ %><div class="d-flex justify-content-between border-bottom py-2"><span><%= item.name %> x <%= item.quantity %></span><span>R$ <%= (item.price*item.quantity).toFixed(2) %></span><form action="/carrinho/remover/<%= idx %>" method="post"><button class="btn btn-sm btn-outline-light">Remover</button></form></div><% }) %><p class="mt-3">Subtotal: <strong class="price">R$ <%= subtotal.toFixed(2) %></strong></p><form action="/carrinho/frete" method="post" class="d-flex gap-2"><input name="zipcode" class="form-control" placeholder="CEP"><button class="btn btn-outline-light">Calcular frete</button></form><% shippingOptions.forEach(s=>{ %><div><%= s.service %> - R$ <%= s.price %> (<%= s.days %> dias)</div><% }) %><a href="/checkout" class="btn btn-gold mt-3">Finalizar compra</a></div>
