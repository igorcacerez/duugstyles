<section class="page-hero category-hero">
  <div class="container">
    <nav class="breadcrumb-line" aria-label="breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <strong><%= category.name %></strong>
    </nav>
    <span class="eyebrow">Categoria Duug Styles</span>
    <h1><%= category.name %></h1>
    <p><%= category.seoText || 'Pecas streetwear masculinas com modelagem atual, tecido premium e compra rapida.' %></p>
    <form class="search-panel filter-panel" action="/categoria/<%= category.slug %>" method="get">
      <select class="form-select" name="tamanho" aria-label="Filtrar por tamanho">
        <option value="">Todos os tamanhos</option>
        <% sizes.forEach((size) => { %><option value="<%= size.id %>" <%= filters.sizeId === size.id ? 'selected' : '' %>><%= size.name %></option><% }) %>
      </select>
      <select class="form-select" name="cor" aria-label="Filtrar por cor">
        <option value="">Todas as cores</option>
        <% colors.forEach((color) => { %><option value="<%= color.id %>" <%= filters.colorId === color.id ? 'selected' : '' %>><%= color.name %></option><% }) %>
      </select>
      <button class="btn btn-gold" type="submit">Filtrar</button>
      <a class="btn btn-light-ghost" href="/categoria/<%= category.slug %>">Limpar</a>
    </form>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-heading">
      <div>
        <span class="eyebrow"><%= products.length %> produto(s)</span>
        <h2>Escolha, calcule o frete e compre</h2>
      </div>
    </div>
    <% if (products.length) { %>
      <div class="product-grid">
        <% products.forEach((p) => { %>
          <%- include('../partials/product-card', { product: p }) %>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <i data-lucide="package-search"></i>
        <h2>Categoria sem produtos ativos</h2>
        <p>Veja outros drops disponiveis na loja.</p>
        <a class="btn btn-gold" href="/busca">Ver produtos</a>
      </div>
    <% } %>
  </div>
</section>
