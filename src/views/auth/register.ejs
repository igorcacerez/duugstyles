<section class="page-hero compact-hero">
  <div class="container auth-wrap">
    <div class="auth-card wide">
      <span class="eyebrow">Nova conta</span>
      <h1>Cadastro</h1>
      <p>Crie sua conta para acompanhar pedidos e acelerar proximas compras.</p>
      <form method="post" action="/cadastro" data-loading-form>
        <div class="form-grid">
          <label>Nome completo<input class="form-control" name="fullName" autocomplete="name" required></label>
          <label>E-mail<input class="form-control" name="email" type="email" autocomplete="email" required></label>
          <label>CPF/CNPJ<input class="form-control" name="cpfCnpj" autocomplete="off"></label>
          <label>Telefone<input class="form-control" name="phone" inputmode="tel" autocomplete="tel"></label>
        </div>
        <label>Senha<input class="form-control" name="password" type="password" autocomplete="new-password" required></label>
        <button class="btn btn-gold checkout-button" type="submit">
          <i data-lucide="user-plus"></i>
          Criar conta
        </button>
      </form>
      <a class="text-link" href="/login">Ja tenho conta</a>
    </div>
  </div>
</section>
