<section class="page-hero compact-hero">
  <div class="container auth-wrap">
    <div class="auth-card">
      <span class="eyebrow">Minha conta</span>
      <h1>Entrar</h1>
      <p>Acesse seus pedidos, favoritos e checkout mais rapido.</p>
      <form method="post" action="/login" data-loading-form>
        <label>E-mail<input class="form-control" name="email" type="email" autocomplete="email" required></label>
        <label>Senha<input class="form-control" name="password" type="password" autocomplete="current-password" required></label>
        <button class="btn btn-gold checkout-button" type="submit">
          <i data-lucide="log-in"></i>
          Entrar
        </button>
      </form>
      <a class="text-link" href="/cadastro">Criar conta</a>
    </div>
  </div>
</section>
