<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= (meta && meta.title) || 'Duug Styles | Moda Masculina Streetwear' %></title>
  <meta name="description" content="<%= (meta && meta.description) || 'Streetwear masculino premium com camisetas oversized, moletons e pecas urbanas.' %>">
  <meta name="keywords" content="<%= (meta && meta.keywords) || 'streetwear masculino, camisetas oversized, moletons masculinos, moda urbana' %>">
  <meta name="robots" content="index,follow,max-image-preview:large">
  <link rel="canonical" href="<%= (meta && meta.canonical) || appUrl %>">
  <meta property="og:locale" content="pt_BR">
  <meta property="og:site_name" content="Duug Styles">
  <meta property="og:title" content="<%= (meta && meta.title) || 'Duug Styles' %>">
  <meta property="og:description" content="<%= (meta && meta.description) || 'Streetwear masculino premium.' %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= (meta && meta.canonical) || appUrl %>">
  <meta property="og:image" content="<%= (meta && meta.image) || (appUrl + '/public/images/hero-streetwear-duug.png') %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= (meta && meta.title) || 'Duug Styles' %>">
  <meta name="twitter:description" content="<%= (meta && meta.description) || 'Streetwear masculino premium.' %>">
  <meta name="theme-color" content="#080705">
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="preconnect" href="https://unpkg.com">
  <link rel="preload" href="/public/images/hero-streetwear-duug.png" as="image">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/public/css/styles.css">
  <script type="application/ld+json">
  <%- JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Duug Styles',
    url: appUrl,
    logo: appUrl + '/public/images/hero-streetwear-duug.png',
    sameAs: []
  }) %>
  </script>
  <script type="application/ld+json">
  <%- JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Duug Styles',
    url: appUrl,
    potentialAction: {
      '@type': 'SearchAction',
      target: appUrl + '/busca?q={search_term_string}',
      'query-input': 'required name=search_term_string'
    }
  }) %>
  </script>
</head>
<body>
  <div class="topbar">
    <div class="container topbar-inner">
      <span>Frete calculado no produto</span>
      <span>Compra rapida e pagamento seguro</span>
      <span>Troca facil em ate 7 dias</span>
    </div>
  </div>
  <nav class="navbar navbar-expand-lg storefront-nav sticky-top">
    <div class="container nav-inner">
      <a class="navbar-brand brand-mark" href="/" aria-label="Duug Styles home">
        <span>DUUG</span><strong>STYLES</strong>
      </a>
      <form class="nav-search" action="/busca" method="get" role="search">
        <i data-lucide="search"></i>
        <input name="q" type="search" placeholder="Buscar camiseta, moletom..." aria-label="Buscar produtos">
      </form>
      <div class="nav-actions">
        <a class="nav-icon-link" href="/favoritos" aria-label="Lista de desejos">
          <i data-lucide="heart"></i>
          <span class="wishlist-count" data-wishlist-count>0</span>
        </a>
        <a class="btn btn-gold nav-cart" href="/carrinho">
          <i data-lucide="shopping-bag"></i>
          Carrinho
          <% if (cartCount > 0) { %><span><%= cartCount %></span><% } %>
        </a>
      </div>
    </div>
  </nav>
  <main><%- body %></main>
  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <a class="brand-mark footer-brand" href="/"><span>DUUG</span><strong>STYLES</strong></a>
        <p>Streetwear masculino premium para quem quer comprar rapido, vestir melhor e receber com previsibilidade.</p>
      </div>
      <div>
        <h2>Loja</h2>
        <a href="/busca">Buscar produtos</a>
        <a href="/favoritos">Lista de desejos</a>
        <a href="/carrinho">Carrinho</a>
      </div>
      <div>
        <h2>Ajuda</h2>
        <a href="/trocas-e-devolucoes">Trocas e devolucoes</a>
        <a href="/faq">FAQ</a>
        <a href="/contato">Contato</a>
      </div>
    </div>
    <div class="container footer-bottom">
      <small>&copy; <%= new Date().getFullYear() %> Duug Styles. Todos os direitos reservados.</small>
    </div>
  </footer>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script src="/public/js/main.js"></script>
</body>
</html>
