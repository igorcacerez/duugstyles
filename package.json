{
  "name": "duug-styles",
  "version": "1.0.0",
  "description": "Duug Styles e-commerce monolith with Express + Sequelize + MySQL",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "sequelize-cli db:migrate --config src/config/database-cli.js --migrations-path src/database/migrations",
    "db:seed": "sequelize-cli db:seed:all --config src/config/database-cli.js --seeders-path src/database/seeders",
    "db:reset": "sequelize-cli db:migrate:undo:all --config src/config/database-cli.js --migrations-path src/database/migrations && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "method-override": "^3.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.3",
    "sequelize": "^6.37.3",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "sequelize-cli": "^6.6.2"
  }
}
